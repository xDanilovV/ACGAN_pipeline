{
  "input_format": "mea",
  "mea_label_mode": "class",
  "shape_mode": "auto",
  "resize_mode": "area",
  "auto_max_pixels": 65536,
  "auto_max_height": 512,
  "auto_max_width": 256,
  "auto_multiple": 16,
  "peak_crop": true,
  "epochs": 30,
  "batch_size": 16,
  "samples_per_class": 5,
  "checkpoint_every": 5,
  "sample_every": 5,
  "lr_g": 0.0002,
  "lr_d": 0.00002,
  "class_loss_weight": 1.0,
  "tv_loss_weight": 0.0001,
  "projection_scale": 0.0,
  "discriminator_base_channels": 16,
  "discriminator_use_norm": false,
  "generator_base_channels": 256,
  "generator_steps": 2,
  "discriminator_update_every": 2,
  "label_smoothing": 0.1,
  "instance_noise_std": 0.1,
  "instance_noise_decay_epochs": 30,
  "classifier": "svm",
  "synthetic_viz_denormalized": true
}
